                "type": "text/javascript",
                "exec": [
                  "pm.test('Protected endpoint status', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
