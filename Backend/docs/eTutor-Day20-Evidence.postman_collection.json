{
  "info": {
    "_postman_id": "8e2b7c97-8b3f-4f54-9a73-4a1578d1f5be",
    "name": "eTutor Day20 Evidence",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost/eTutor/Backend/api/index.php"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "A) Health Check",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}?controller=health",
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "key": "controller",
                  "value": "health"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var body = pm.response.json();",
                  "pm.test('Health status OK', function () {",
                  "  pm.expect(body.status).to.eql('OK');",
                  "});",
                  "pm.test('Has service and time', function () {",
                  "  pm.expect(body).to.have.property('service');",
                  "  pm.expect(body).to.have.property('time');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "B) Auth Token",
      "item": [
        {
          "name": "POST login (optional)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"admin@example.com\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}?controller=auth",
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "key": "controller",
                  "value": "auth"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200 or 401', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "});",
                  "var contentType = pm.response.headers.get('Content-Type') || '';",
                  "if (contentType.includes('application/json')) {",
                  "  var body = pm.response.json();",
                  "  if (body.access_token) {",
                  "    pm.collectionVariables.set('token', body.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "C) Request Logging Evidence",
      "item": [
